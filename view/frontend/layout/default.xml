<?xml version="1.0"?>
<!--
/**
 * @description Default layout customizations
 * @author      C. M. de Picciotto <d3p1@d3p1.dev> (https://d3p1.dev/)
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="catalog.compare.link" remove="true"/>

        <move element="catalog.compare.sidebar"
              destination="catalog.compare.config.sidebar"/>

        <referenceBlock name="top.links">
            <block class="Magento\Framework\View\Element\Template"
                   name="catalog.compare.config.link"
                   template="Magento_Catalog::product/compare/link.phtml"
                   before="-"
                   ifconfig="catalog/compare/active">
                <arguments>
                    <argument name="jsLayout" xsi:type="array">
                        <item name="components" xsi:type="array">
                            <item name="compareProducts" xsi:type="array">
                                <item name="component" xsi:type="string">Magento_Catalog/js/view/compare-products</item>
                            </item>
                        </item>
                    </argument>
                </arguments>
            </block>
        </referenceBlock>

        <referenceContainer name="sidebar.additional">
            <block class="Magento\Framework\View\Element\Template"
                   name="catalog.compare.config.sidebar"
                   template="Bina_CatalogCompare::catalog/product/compare/sidebar.phtml"
                   ifconfig="catalog/compare/active"/>
        </referenceContainer>
    </body>
</page>