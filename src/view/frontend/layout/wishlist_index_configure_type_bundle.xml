<?xml version="1.0"?>
<!--
/**
 * @description Wishlist bundle configure customizations
 * @author      C. M. de Picciotto <d3p1@d3p1.dev> (https://d3p1.dev/)
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <move element="view.addto.compare.bundle"
              destination="view.addto.compare.config.bundle"/>

        <referenceBlock name="product.info.addto.bundle">
            <block class="Magento\Catalog\Block\Product\View\AddTo\Compare"
                   name="view.addto.compare.config.bundle"
                   after="view.addto.wishlist"
                   template="D3p1_CatalogCompare::catalog/product/view/addto/compare.phtml"
                   ifconfig="catalog/compare/active"/>
        </referenceBlock>
    </body>
</page>