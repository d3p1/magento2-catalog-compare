<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <move element="catalogsearch.product.addto.compare"
              destination="catalogsearch.product.addto.config.compare"/>

        <referenceBlock name="catalogsearch.product.addto">
            <block class="Magento\Catalog\Block\Product\ProductList\Item\AddTo\Compare"
                   name="catalogsearch.product.addto.config.compare"
                   template="D3p1_CatalogCompare::catalog/product/list/addto/compare.phtml"
                   ifconfig="catalog/compare/active"/>
        </referenceBlock>
    </body>
</page>
